extern func __poc_write(fd::int, buff::*char, len::int) -> int;
extern func strlen(str::*char) -> int;

func puts(str::*char) -> int {
    ret __poc_write(1, str, strlen(str));
}

func put_digit(n::int) -> void {
    if(n < 0 || n > 9){
        ret;
    }

    if(n == 9){
        puts("9");
    }

    if(n == 8){
        puts("8");
    }

    if(n == 7){
        puts("7");
    }

    if(n == 6){
        puts("6");
    }

    if(n == 5){
        puts("5");
    }

    if(n == 4){
        puts("4");
    }

    if(n == 3){
        puts("3");
    }

    if(n == 2){
        puts("2");
    }

    if(n == 1){
        puts("1");
    }

    if(n == 0){
        puts("0");
    }
}

func printInt(num::int) -> void {
    if(num == 0){
        put_digit(0);
        ret;
    }

    if(num < 0){
        puts("-");
        num = -num;
    }

    print_int_rec(num);
}

func print_int_rec(num::int) -> void {
    if(num == 0){
        ret;
    }

    print_int_rec(num / 10);

    n::int = num - (num / 10 * 10);
    put_digit(n);
}
